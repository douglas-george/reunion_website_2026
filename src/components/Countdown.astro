---
interface Props { target: string; }
const { target } = Astro.props;
---
<div class="countdown" data-target={target}>
  <div class="cd"><b data-d>--</b><span>Days</span></div>
  <div class="cd"><b data-h>--</b><span>Hours</span></div>
  <div class="cd"><b data-m>--</b><span>Minutes</span></div>
  <div class="cd"><b data-s>--</b><span>Seconds</span></div>
</div>
<script>
  const el = document.querySelector('.countdown');
  if (el) {
    const target = new Date(el.getAttribute('data-target') || '').getTime();
    const set = (sel: string, val: string) => {
      const n = el.querySelector(sel);
      if (n) n.textContent = val;
    };
    const tick = () => {
      const diff = Math.max(0, target - Date.now());
      const sec = Math.floor(diff / 1000);
      set('[data-d]', String(Math.floor(sec / 86400)));
      set('[data-h]', String(Math.floor((sec % 86400) / 3600)).padStart(2, '0'));
      set('[data-m]', String(Math.floor((sec % 3600) / 60)).padStart(2, '0'));
      set('[data-s]', String(sec % 60).padStart(2, '0'));
    };
    tick();
    setInterval(tick, 1000);
  }
</script>
