---
import { initials } from '../lib/site';
interface Meal { name: string; title?: string; description?: string; time?: string; dishes?: string[]; tags?: string[]; cook?: string; }
interface Props { day?: string; meals: Meal[]; }
const { meals = [] } = Astro.props;
---
<div class="mgrid">
  {meals.map((m) => (
    <div class="mcard">
      <div class="kicker">{m.name}</div>
      <h3>{m.title ?? m.name}</h3>
      {m.description && <p class="mdesc">{m.description}</p>}
      {m.dishes && m.dishes.map((d) => (
        <div class="dish"><span>{d}</span>{m.time && <span>{m.time}</span>}</div>
      ))}
      {m.tags && m.tags.length > 0 && (
        <div class="tags">{m.tags.map((t) => <span class="tag">{t}</span>)}</div>
      )}
      {m.cook && (
        <div class="cook"><span class="av">{initials(m.cook)}</span> {m.cook}</div>
      )}
    </div>
  ))}
</div>
