---
import Countdown from './Countdown.astro';
import type { SiteConfig } from '../lib/site';
interface Props { site: SiteConfig; }
const { site } = Astro.props;
---
<header id="top">
  <div class="scene" aria-hidden="true">
    <svg viewBox="0 0 1440 760" preserveAspectRatio="xMidYMax slice" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#2E4A6B"></stop>
          <stop offset="0.4" stop-color="#6C7C9C"></stop>
          <stop offset="0.68" stop-color="#E59E62"></stop>
          <stop offset="1" stop-color="#F6C98A"></stop>
        </linearGradient>
        <radialGradient id="sun" cx="50%" cy="50%" r="50%">
          <stop offset="0" stop-color="#FFF4DC"></stop>
          <stop offset="0.5" stop-color="#FCD68B"></stop>
          <stop offset="1" stop-color="#F6C98A" stop-opacity="0"></stop>
        </radialGradient>
        <linearGradient id="water" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#E7B777"></stop>
          <stop offset="0.5" stop-color="#9BB0C0"></stop>
          <stop offset="1" stop-color="#7E97A6"></stop>
        </linearGradient>
        <linearGradient id="sand" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#EBD7AE"></stop>
          <stop offset="1" stop-color="#D8BE8C"></stop>
        </linearGradient>
      </defs>
      <rect width="1440" height="760" fill="url(#sky)"></rect>
      <circle cx="720" cy="350" r="230" fill="url(#sun)"></circle>
      <circle cx="720" cy="350" r="66" fill="#FFF1D2"></circle>
      <rect y="430" width="1440" height="150" fill="url(#water)"></rect>
      <rect y="428" width="1440" height="4" fill="#C98B57" opacity="0.45"></rect>
      <g fill="#FFE9C2" opacity="0.5">
        <rect x="694" y="442" width="52" height="6" rx="3"></rect>
        <rect x="700" y="458" width="40" height="6" rx="3"></rect>
        <rect x="688" y="474" width="64" height="6" rx="3"></rect>
        <rect x="702" y="492" width="36" height="6" rx="3"></rect>
        <rect x="684" y="510" width="72" height="6" rx="3"></rect>
      </g>
      <g transform="translate(995,392)" fill="#2C4A52">
        <path d="M0 38 L34 38 L27 50 L7 50 Z"></path>
        <path d="M17 4 L17 38 L1 38 Z"></path>
        <path d="M19 8 L19 38 L34 38 Z"></path>
      </g>
      <path d="M0 545 C 300 525, 560 560, 820 552 C 1080 545, 1260 565, 1440 548 L1440 760 L0 760 Z" fill="url(#sand)"></path>
      <g stroke="#3F6356" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.9">
        <path d="M70 760 C 64 700, 60 680, 52 650"></path>
        <path d="M84 760 C 84 706, 86 684, 92 656"></path>
        <path d="M100 760 C 96 712, 94 690, 84 666"></path>
        <path d="M120 760 C 122 710, 126 690, 136 664"></path>
        <path d="M138 760 C 134 716, 132 700, 124 678"></path>
      </g>
      <g stroke="#3F6356" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.9">
        <path d="M1320 760 C 1314 704, 1312 686, 1304 658"></path>
        <path d="M1336 760 C 1336 708, 1340 688, 1348 660"></path>
        <path d="M1352 760 C 1348 714, 1346 694, 1336 670"></path>
        <path d="M1372 760 C 1374 710, 1378 692, 1388 666"></path>
      </g>
      <g stroke="#2E4A6B" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.55">
        <path d="M540 232 q12 -10 24 0"></path>
        <path d="M566 226 q12 -10 24 0"></path>
        <path d="M900 250 q10 -8 20 0"></path>
      </g>
    </svg>
  </div>
  <div class="hero-inner">
    {site.eyebrow && <p class="eyebrow">{site.eyebrow}</p>}
    <h1 class="title">{site.title}</h1>
    {site.tagline && <p class="hero-sub">{site.tagline}</p>}
    <div class="hero-meta">
      <span>📅 {site.dates_label}</span>
      <span>📍 {site.location}</span>
      {site.headcount && <span>👪 {site.headcount}</span>}
    </div>
    <Countdown target={site.countdown_target} />
  </div>
</header>
