---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import GlanceCards from '../components/GlanceCards.astro';
import Timeline from '../components/Timeline.astro';
import MealCards from '../components/MealCards.astro';
import { getCollection } from 'astro:content';
import { getSite } from '../lib/site';

const site = getSite();
const days = (await getCollection('itinerary')).sort((a, b) => a.data.order - b.data.order);
const mealDays = (await getCollection('meals')).sort((a, b) => a.data.order - b.data.order);
const infoPages = (await getCollection('pages'))
  .filter((p) => !p.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const firstDay = days[0];
const firstMeals = mealDays[0];
---
<BaseLayout current="/">
  <Hero site={site} />

  <div class="wrap glance"><GlanceCards items={site.glance ?? []} /></div>

  {site.welcome_heading && (
    <section class="band welcome">
      <div class="wrap inner">
        <p class="eyebrow">Welcome</p>
        <h2>{site.welcome_heading}</h2>
        {site.welcome_body && <p>{site.welcome_body}</p>}
      </div>
    </section>
  )}

  {firstDay && (
    <section class="band">
      <div class="wrap">
        <div class="shead">
          <p class="eyebrow">The plan</p>
          <h2>Daily itinerary</h2>
          <p>A loose schedule — show up when you can, leave when you must.</p>
        </div>
        <Timeline events={firstDay.data.events} />
        <p style="text-align:center;margin-top:30px">
          <a href="/itinerary" style="color:var(--forest);font-weight:500">See the full itinerary →</a>
        </p>
      </div>
    </section>
  )}

  {firstMeals && (
    <section class="band meals">
      <div class="wrap">
        <div class="shead">
          <p class="eyebrow">In the kitchen</p>
          <h2>Meal plan</h2>
          <p>Who's cooking what — and how to flag a food allergy.</p>
        </div>
        <MealCards day={firstMeals.data.day} meals={firstMeals.data.meals} />
        <p style="text-align:center;margin-top:30px">
          <a href="/meals" style="color:var(--gold);font-weight:500">All meals →</a>
        </p>
      </div>
    </section>
  )}

  {infoPages.length > 0 && (
    <section class="band info">
      <div class="wrap">
        <div class="shead">
          <p class="eyebrow">Everything else</p>
          <h2>Travel &amp; good-to-know</h2>
          <p>The practical stuff, in one place.</p>
        </div>
        <div class="grid">
          {infoPages.map((p) => (
            <a class="icard" href={`/${p.id}`}>
              <div class="ico">{p.data.icon}</div>
              <h3>{p.data.title}</h3>
              <p>{p.data.intro ?? ''}</p>
            </a>
          ))}
        </div>
        <p class="addhint">✦ This is a starting framework — add a file to <code>content/pages/</code> and a new page and nav link appear automatically.</p>
      </div>
    </section>
  )}
</BaseLayout>
