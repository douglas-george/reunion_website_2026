---
import BaseLayout from '../layouts/BaseLayout.astro';
import MealPlan from '../components/MealPlan.astro';
import { getCollection } from 'astro:content';
import { getSite } from '../lib/site';
const site = getSite();
const mealDays = (await getCollection('meals')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Meals" current="meals">
  <div class="page-hero">
    <p class="eyebrow">In the kitchen</p>
    <h1>Meal plan</h1>
  </div>
  <section class="band meals">
    <div class="wrap">
      <div class="shead">
        <p class="eyebrow">Family kitchen</p>
        <h2>Gluten-free by default</h2>
        {site.meal_intro && <p>{site.meal_intro}</p>}
      </div>
      <MealPlan days={mealDays} />
      {site.meal_notes && site.meal_notes.length > 0 && (
        <div class="meal-notes">
          <h3>A few things all week</h3>
          <ul>{site.meal_notes.map((n) => <li>{n}</li>)}</ul>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
